{
  "name": "@portalflow/cli",
  "version": "1.1.20",
  "description": "PortalFlow CLI for running and managing browser automations",
  "type": "module",
  "bin": {
    "portalflow": "dist/index.js"
  },
  "scripts": {
    "build:schema": "cd ../schema && npm run build",
    "prebuild": "npm run build:schema",
    "predev": "npm run build:schema",
    "pretest": "npm run build:schema",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@portalflow/schema": "*",
    "@anthropic-ai/sdk": "^0.52.0",
    "@clack/prompts": "^0.9.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "openai": "^4.77.0",
    "picocolors": "^1.1.1",
    "pino": "^9.6.0",
    "playwright": "^1.50.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
