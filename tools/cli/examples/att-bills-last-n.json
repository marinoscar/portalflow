{
  "id": "d2e2f6aa-4f3b-4c4b-9c8a-4f3b4c4b9c8a",
  "name": "AT&T — Download last N bills",
  "version": "1.0.0",
  "description": "Logs into AT&T, navigates to billing history, and downloads the last N months of bills as PDFs. N is configurable at runtime via the billCount input.",
  "goal": "Sign in to AT&T account management and download the most recent N billing statements as PDFs.",
  "inputs": [
    {
      "name": "billCount",
      "type": "number",
      "required": true,
      "source": "cli_arg",
      "value": "3",
      "description": "Number of most recent bills to download"
    },
    {
      "name": "password",
      "type": "secret",
      "required": true,
      "source": "vaultcli",
      "value": "att",
      "description": "Password retrieved from vaultcli"
    }
  ],
  "steps": [
    {
      "id": "step-1",
      "name": "Go to AT&T sign-in",
      "type": "navigate",
      "action": {
        "url": "https://signin.att.com/dynamic/iamLRR/LrrController?IAM_OP=login&appName=m14186"
      },
      "validation": { "type": "url_contains", "value": "signin.att.com" },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 30000
    },
    {
      "id": "step-2",
      "name": "Enter username",
      "type": "interact",
      "action": { "interaction": "type", "value": "oscar@marin.cr" },
      "aiGuidance": "The username or AT&T ID field near the top of the login form.",
      "selectors": {
        "primary": "#userID",
        "fallbacks": [
          "input[name=\"userID\"]",
          "app-user-input > div.form-row.space-below > input.textfield"
        ]
      },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-3",
      "name": "Continue with username",
      "type": "interact",
      "action": { "interaction": "click" },
      "aiGuidance": "The primary Continue button below the username field.",
      "selectors": {
        "primary": "#continueFromUserLogin",
        "fallbacks": ["button.btn-full-width.btn-primary"]
      },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-4",
      "name": "Wait for password form",
      "type": "wait",
      "action": { "condition": "selector", "value": "#password" },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-5",
      "name": "Enter password",
      "type": "interact",
      "action": { "interaction": "type", "inputRef": "password" },
      "aiGuidance": "The password field in the sign-in form, usually below the username step.",
      "selectors": {
        "primary": "#password",
        "fallbacks": ["input[name=\"password\"]", "input.textfield-password"]
      },
      "onFailure": "abort",
      "maxRetries": 3,
      "timeout": 10000
    },
    {
      "id": "step-6",
      "name": "Sign in",
      "type": "interact",
      "action": { "interaction": "click" },
      "aiGuidance": "The Sign in button at the bottom of the password form.",
      "selectors": {
        "primary": "#signin",
        "fallbacks": ["button.btn-full-width.btn-primary"]
      },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-7",
      "name": "Wait for sign-in to finish",
      "type": "wait",
      "action": { "condition": "network_idle" },
      "onFailure": "skip",
      "maxRetries": 1,
      "timeout": 15000
    },
    {
      "id": "step-8",
      "name": "Choose SMS OTP method",
      "type": "interact",
      "action": { "interaction": "check" },
      "aiGuidance": "The radio button for receiving the code by text message.",
      "selectors": {
        "primary": "#contactMethod2",
        "fallbacks": ["input[name=\"selectedOTPDest\"]"]
      },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-9",
      "name": "Send OTP code",
      "type": "interact",
      "action": { "interaction": "click" },
      "aiGuidance": "The Send button beneath the OTP delivery method choices.",
      "selectors": {
        "primary": "#chooseMethodSendButton",
        "fallbacks": ["button.btn-primary"]
      },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-10",
      "name": "Wait for OTP entry",
      "type": "wait",
      "action": { "condition": "selector", "value": "#codeValue" },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-11",
      "name": "Retrieve OTP code",
      "type": "tool_call",
      "action": {
        "tool": "smscli",
        "command": "get-otp",
        "args": { "sender": "", "pattern": "\\d{6}" },
        "outputName": "otpCode"
      },
      "onFailure": "abort",
      "maxRetries": 1,
      "timeout": 120000
    },
    {
      "id": "step-12",
      "name": "Enter OTP code",
      "type": "interact",
      "action": { "interaction": "type", "inputRef": "otpCode" },
      "aiGuidance": "The one-time code input field on the OTP verification page.",
      "selectors": {
        "primary": "#codeValue",
        "fallbacks": ["input[name=\"codeValue\"]"]
      },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-13",
      "name": "Continue after OTP",
      "type": "interact",
      "action": { "interaction": "click" },
      "aiGuidance": "The Continue button below the OTP entry field.",
      "selectors": {
        "primary": "#enterCodeSendButton",
        "fallbacks": ["button.btn-primary"]
      },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 10000
    },
    {
      "id": "step-14",
      "name": "Wait for login to complete",
      "type": "wait",
      "action": { "condition": "network_idle" },
      "onFailure": "skip",
      "maxRetries": 1,
      "timeout": 15000
    },
    {
      "id": "step-15",
      "name": "Open billing history",
      "type": "navigate",
      "action": {
        "url": "https://www.att.com/acctmgmt/billing/billandpaymenthistory?filter=bill"
      },
      "validation": { "type": "url_contains", "value": "/acctmgmt/billing/billandpaymenthistory" },
      "onFailure": "abort",
      "maxRetries": 2,
      "timeout": 30000
    },
    {
      "id": "step-16",
      "name": "Download last {{billCount}} bills",
      "type": "loop",
      "action": {
        "maxIterations": "{{billCount}}",
        "items": {
          "description": "Each expandable bill row in the billing history list, representing a single month's statement with its amount and date range. Newest bills appear first.",
          "selectorPattern": "[data-testid^=\"activityDetails_accordion_\"]",
          "itemVar": "billRow",
          "order": "newest"
        },
        "indexVar": "billIndex"
      },
      "onFailure": "skip",
      "maxRetries": 0,
      "timeout": 600000,
      "substeps": [
        {
          "id": "step-16.1",
          "name": "Expand bill row for month index {{billIndex}}",
          "type": "interact",
          "action": { "interaction": "click" },
          "selectors": { "primary": "{{billRow}}" },
          "aiGuidance": "The bill accordion row at position {{billIndex}}, currently collapsed",
          "onFailure": "skip",
          "maxRetries": 2,
          "timeout": 10000
        },
        {
          "id": "step-16.2",
          "name": "Open PDF download menu",
          "type": "interact",
          "action": { "interaction": "click" },
          "selectors": {
            "primary": "{{billRow}} ~ * button.dropdown-.btn-primary",
            "fallbacks": ["button.dropdown-.btn-primary"]
          },
          "aiGuidance": "The Download PDF dropdown button in the currently expanded bill details area for month {{billIndex}}",
          "onFailure": "abort",
          "maxRetries": 2,
          "timeout": 10000
        },
        {
          "id": "step-16.3",
          "name": "Select regular PDF",
          "type": "interact",
          "action": { "interaction": "click" },
          "selectors": {
            "primary": "li[aria-label=\"Regular PDF\"]",
            "fallbacks": ["li[role=\"option\"]", "li.option-list-item"]
          },
          "aiGuidance": "The Regular PDF option in the just-opened download menu",
          "onFailure": "abort",
          "maxRetries": 2,
          "timeout": 10000
        },
        {
          "id": "step-16.4",
          "name": "Download bill PDF",
          "type": "download",
          "action": { "trigger": "click", "expectedFilename": "*.pdf" },
          "onFailure": "abort",
          "maxRetries": 2,
          "timeout": 30000
        },
        {
          "id": "step-16.5",
          "name": "Wait for page to settle before next iteration",
          "type": "wait",
          "action": { "condition": "network_idle" },
          "onFailure": "skip",
          "maxRetries": 0,
          "timeout": 10000
        }
      ]
    }
  ],
  "tools": [
    { "name": "vaultcli", "config": {} },
    { "name": "smscli", "config": {} }
  ],
  "settings": {
    "headless": false,
    "defaultTimeout": 30000,
    "screenshotOnFailure": true
  }
}
