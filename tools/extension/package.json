{
  "name": "@portalflow/extension",
  "version": "1.0.2",
  "description": "PortalFlow Chrome extension: record browser workflows and export them as automation JSON",
  "private": true,
  "type": "module",
  "scripts": {
    "build:schema": "cd ../schema && npm run build",
    "prebuild": "npm run build:schema",
    "predev": "npm run build:schema",
    "dev": "vite",
    "build": "vite build",
    "typecheck": "npm run build:schema && tsc --noEmit",
    "package": "npm run build && cd dist && zip -r ../portalflow-extension.zip ."
  },
  "dependencies": {
    "@portalflow/schema": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
